{
  "name": "mindmap-lite",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "migrate": "wrangler d1 migrations apply mindmap-lite-db --local",
    "migrate:remote": "wrangler d1 migrations apply mindmap-lite-db --remote",
    "generate": "drizzle-kit generate"
  },
  "private": true,
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "honox": "^0.1.55",
    "konva": "^10.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/vite": "^4.0.9",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.9",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
