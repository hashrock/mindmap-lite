{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mindmap-lite",
  "main": "./src/index.ts",
  "compatibility_date": "2026-03-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "../web/dist",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mindmap-lite-db",
      "database_id": "aeb23f2c-ead6-4495-854b-dfec9fef53ae"
    }
  ]
}
